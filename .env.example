# Discord bot token (alternatively, put token in discord_token.txt for Docker secrets)
DISCORD_TOKEN=your-bot-token-here

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/records?sslmode=disable

# Path to RAID mount for disk monitoring (leave empty to disable)
RAID_MOUNT_PATH=/mnt/raid0

# Disk usage percentage threshold to trigger warnings (default: 90)
DISK_WARN_THRESHOLD=90

# Channel name where disk warnings are sent (default: bot-alerts)
DISK_WARN_CHANNEL=bot-alerts

# Google Gemini API key for TLDR summaries (optional, feature disabled without it)
GEMINI_API_KEY=your-gemini-api-key-here

# TLDR rate limits
TLDR_CHANNEL_LIMIT=1
TLDR_GLOBAL_LIMIT=5
